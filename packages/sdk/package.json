{
  "name": "@frankensqlite/sdk",
  "version": "0.1.0",
  "description": "Async TypeScript SDK for FrankenSQLite browser bindings",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "peerDependencies": {
    "@frankensqlite/core": "^0.1.0"
  },
  "dependencies": {
    "@frankensqlite/worker": "workspace:*"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
