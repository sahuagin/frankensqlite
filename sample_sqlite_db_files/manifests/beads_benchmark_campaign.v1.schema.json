{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://frankensqlite.local/schemas/sample_sqlite_db_files/beads_benchmark_campaign.v1.schema.json",
  "title": "FrankenSQLite Beads Benchmark Campaign (v1)",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "campaign_id",
    "title",
    "working_benchmark_root_relpath",
    "beads_data_relpath",
    "fixtures",
    "placement_profiles",
    "hardware_classes",
    "retry_policies",
    "build_profiles",
    "seed_policies",
    "matrix_rows",
    "artifact_contract"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "fsqlite-e2e.beads_benchmark_campaign.v1"
    },
    "campaign_id": {
      "$ref": "#/$defs/id"
    },
    "title": {
      "$ref": "#/$defs/non_empty_string"
    },
    "working_benchmark_root_relpath": {
      "$ref": "#/$defs/non_empty_string"
    },
    "beads_data_relpath": {
      "$ref": "#/$defs/non_empty_string"
    },
    "fixtures": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/fixture"
      }
    },
    "placement_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/placement_profile"
      }
    },
    "hardware_classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/hardware_class"
      }
    },
    "retry_policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/retry_policy"
      }
    },
    "build_profiles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/build_profile"
      }
    },
    "seed_policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/seed_policy"
      }
    },
    "matrix_rows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/matrix_row"
      }
    },
    "artifact_contract": {
      "$ref": "#/$defs/artifact_contract"
    }
  },
  "$defs": {
    "non_empty_string": {
      "type": "string",
      "minLength": 1
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_\\-\\.]*$"
    },
    "sha256": {
      "type": "string",
      "pattern": "^[0-9a-f]{64}$"
    },
    "benchmark_mode": {
      "type": "string",
      "enum": [
        "sqlite_reference",
        "fsqlite_mvcc",
        "fsqlite_single_writer"
      ]
    },
    "fixture": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "fixture_id",
        "source_path",
        "source_sha256",
        "source_size_bytes",
        "working_copy_relpath",
        "working_copy_sha256",
        "working_copy_size_bytes",
        "page_size",
        "journal_mode",
        "capture_rule"
      ],
      "properties": {
        "fixture_id": {
          "$ref": "#/$defs/id"
        },
        "source_path": {
          "$ref": "#/$defs/non_empty_string"
        },
        "source_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "source_size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "working_copy_relpath": {
          "$ref": "#/$defs/non_empty_string"
        },
        "working_copy_sha256": {
          "$ref": "#/$defs/sha256"
        },
        "working_copy_size_bytes": {
          "type": "integer",
          "minimum": 1
        },
        "page_size": {
          "type": "integer",
          "minimum": 1
        },
        "journal_mode": {
          "$ref": "#/$defs/non_empty_string"
        },
        "capture_rule": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "placement_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "description",
        "command_hint",
        "availability"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        },
        "command_hint": {
          "$ref": "#/$defs/non_empty_string"
        },
        "availability": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "hardware_class": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "arch",
        "min_logical_cores",
        "min_numa_nodes",
        "description"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "arch": {
          "$ref": "#/$defs/non_empty_string"
        },
        "min_logical_cores": {
          "type": "integer",
          "minimum": 1
        },
        "min_numa_nodes": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 1
        },
        "description": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "retry_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "max_busy_retries",
        "busy_backoff_ms",
        "busy_backoff_max_ms",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "max_busy_retries": {
          "type": "integer",
          "minimum": 1
        },
        "busy_backoff_ms": {
          "type": "integer",
          "minimum": 1
        },
        "busy_backoff_max_ms": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "build_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "cargo_profile",
        "cargo_args",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "cargo_profile": {
          "$ref": "#/$defs/non_empty_string"
        },
        "cargo_args": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/non_empty_string"
          }
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "seed_policy": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "kind",
        "base_seed",
        "notes"
      ],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "kind": {
          "$ref": "#/$defs/non_empty_string"
        },
        "base_seed": {
          "type": "integer",
          "minimum": 1
        },
        "notes": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    },
    "placement_variant": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "placement_profile_id",
        "hardware_class_id",
        "required"
      ],
      "properties": {
        "placement_profile_id": {
          "$ref": "#/$defs/id"
        },
        "hardware_class_id": {
          "$ref": "#/$defs/id"
        },
        "required": {
          "type": "boolean"
        }
      }
    },
    "matrix_row": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "row_id",
        "fixtures",
        "workload",
        "concurrency",
        "modes",
        "placement_variants",
        "retry_policy_id",
        "build_profile_id",
        "seed_policy_id"
      ],
      "properties": {
        "row_id": {
          "$ref": "#/$defs/id"
        },
        "fixtures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "workload": {
          "$ref": "#/$defs/id"
        },
        "concurrency": {
          "type": "integer",
          "minimum": 1
        },
        "modes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/benchmark_mode"
          }
        },
        "placement_variants": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/placement_variant"
          }
        },
        "retry_policy_id": {
          "$ref": "#/$defs/id"
        },
        "build_profile_id": {
          "$ref": "#/$defs/id"
        },
        "seed_policy_id": {
          "$ref": "#/$defs/id"
        }
      }
    },
    "artifact_contract": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "artifact_root_relpath",
        "bundle_dir_template",
        "result_jsonl_name",
        "summary_md_name",
        "manifest_name",
        "logs_dir_name",
        "profiles_dir_name"
      ],
      "properties": {
        "artifact_root_relpath": {
          "$ref": "#/$defs/non_empty_string"
        },
        "bundle_dir_template": {
          "$ref": "#/$defs/non_empty_string"
        },
        "result_jsonl_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "summary_md_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "manifest_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "logs_dir_name": {
          "$ref": "#/$defs/non_empty_string"
        },
        "profiles_dir_name": {
          "$ref": "#/$defs/non_empty_string"
        }
      }
    }
  }
}
